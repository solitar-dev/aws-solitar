{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".output/**", "build/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"env": [
				// Backend
				"SPRING_PROFILES_ACTIVE",
				"BACKEND_SERVER_PORT",
				"CASSANDRA_URL",
				"CASSANDRA_KEYSPACE",
				"CASSANDRA_LOCAL_DATACENTER",
				"BACKEND_REDIS_URL",
				"RABBITMQ_URL",
				"RABBITMQ_PORT",
				"RABBITMQ_USER",
				"RABBITMQ_PASS",
				// Frontend
				"PUBLIC_API_BASE_URL",
				"SITE_URL",
				"SITE_NAME",
				"SITE_ENV",
				// KGS
				"KGS_SERVER_PORT",
				"KGS_REDIS_URL"
			]
		},
		"test": {
			"dependsOn": ["^test"]
		}
	}
}
