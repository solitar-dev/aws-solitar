{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".output/**", "build/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"env": [
				// Backend
				"SPRING_PROFILES_ACTIVE",
				"BACKEND_SERVER_PORT",
				"AWS_REGION",
				"AWS_ACCESS_KEY_ID",
				"AWS_SECRET_ACCESS_KEY",
				"AWS_DYNAMODB_ENDPOINT",
				"AWS_SQS_ENDPOINT",
				// Frontend
				"PUBLIC_API_BASE_URL",
				"SITE_URL",
				"SITE_NAME",
				"SITE_ENV"
			]
		},
		"test": {
			"dependsOn": ["^test"]
		}
	}
}
